# ──────────────────────────────────────────────
# Sports Betting Arbitrage Scanner -- Environment
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# If ODDS_API_KEY is left blank, the app runs in
# MOCK MODE with synthetic odds data.
# ──────────────────────────────────────────────

# Required: The Odds API key (https://the-odds-api.com/)
# Leave blank for mock mode (offline development)
ODDS_API_KEY=

# Optional: Default sport to scan
# Options: basketball_nba, soccer_epl
DEFAULT_SPORT=basketball_nba

# Optional: Default market type
# Options: h2h, player_points, player_rebounds
DEFAULT_MARKET=h2h

# Optional: Logging level
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
